# Copy this file to ".env" and fill in your Firebase web app credentials.
# Find these in Firebase Console -> Project settings -> Your apps -> SDK setup.

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef

# Namespace for the Firestore data path (any string).
VITE_APP_ID=bingo-multiplayer-app

# Optional: leave blank to sign players in anonymously.
VITE_INITIAL_AUTH_TOKEN=
