rules_version = '2';

// Minimal rules for the Bingo Arena demo. Any signed-in user (including
// anonymous) may read and write room documents. Tighten these before any
// production use — e.g. validate that a writer is a member of the room.
service cloud.firestore {
  match /databases/{database}/documents {
    match /artifacts/{appId}/public/data/rooms/{roomId} {
      allow read, write: if request.auth != null;
    }
  }
}
